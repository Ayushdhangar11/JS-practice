<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View users</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Users - </h1>
    <div>
        <% for(user of data){ %>
            <div class="allusers">
            <h3><span class="at">Id - </span><%=user.id%></h3>
            <h3><span class="at">User - </span>@<%=user.username%></h3>
            <h3><span class="at">Email - </span><%=user.email%></h3>
            <form action="/users/<%= user.id %>/edit" method="get">
                <button>Edit</button>
            </form>
            <!-- <h3><%=user.password%></h3> -->
            <hr>
            </div>
        <% } %>
    </div>
</body>
</html>